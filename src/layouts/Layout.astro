---
import Header from "../components/Header.astro";
const { title } = Astro.props;
import '../styles/global.css';
---
<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title} | 洪水のファンタジア</title>
		<script>
			import UIkit from 'uikit';
			import Icons from 'uikit/dist/js/uikit-icons';
			UIkit.use(Icons);
		</script>
		<link rel="icon" href="/assets/favicon.svg" />
	</head>
	<body class="bg-[url('/src/assets/ファンタジア世界背景用_20260503223944.png')] bg-cover bg-center">
		<div class="bg-gray-950/85 uk-height-viewport">
		<Header />
			<main class="uk-container uk-margin-top">
				<div class="text-stone-200">
					<h1 class="uk-heading-divider !text-fuchsia-50">{title}</h1>
					<slot />
				</div>
				<p class="text-xs text-zinc-300">🄯 2026 洪水のファンタジア. SOURCE CODE: MIT CONTENT: CC BY-SA 4.0</p>
			</main>
		</div>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
